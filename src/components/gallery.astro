---
import { getGallery } from "../utils/sanity";
import { urlFor } from "../utils/image";
const gallery = await getGallery("featured");
export const prerender = false
---

<div
  id="gallery"
  class="w-screen min-h-[250vh] pb-32 light flex flex-col items-center gap-8 relative"
>
  <h1 class="text-6xl my-8 mt-32 gallery-title">Gallery</h1>
  <div class="columns-2 md:columns-3 lg:columns-4 gap-4 w-[80vw] max-w-6xl gallery-container">
    {
      gallery && gallery.gallery?.map((img) => {
        return (
        <div class="gallery-item-wrapper break-inside-avoid">
          <img 
            src={urlFor(img.asset).url()}
            alt={img.caption || "Gallery image"}
            class="gallery-image opacity-0"
            loading="lazy"
          />
          {img.caption && <div class="gallery-caption">{img.caption}</div>}
        </div>
      )
      })
    }
  </div>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

    gsap.from(".gallery-title", {
      opacity: 0,
      y: 20,
      duration: 0.8,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".gallery-title",
        start: "top 80%",
        once: true,
      },
    });

    ScrollTrigger.batch(".gallery-image", {
      start: "top 85%",
      onEnter: (batch) =>
        gsap.to(batch, {
          opacity: 1,
          scale: 1,
          duration: 0.6,
          stagger: 0.08,
          ease: "back.out",
          overwrite: true,
        }),
      onLeaveBack: (batch) =>
        gsap.to(batch, {
          opacity: 0,
          scale: 0.8,
          duration: 0.4,
          stagger: 0.05,
          overwrite: true,
        }),
    });

    document.querySelectorAll(".gallery-image").forEach((img) => {
      img.addEventListener("mouseenter", function () {
        gsap.to(img.nextElementSibling, {
          opacity: 1,
          duration: 0.4,
          ease: "power2.out",
        });
      });

      img.addEventListener("mouseleave", function () {
        gsap.to(img.nextElementSibling, {
          opacity: 0,
          duration: 0.4,
          ease: "power2.in",
        });
      });
    });

</script>

<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  
  .gallery-item-wrapper {
    position: relative;
    border-radius: 5px;
    overflow: hidden;
  }

  .gallery-image {
    width: 100%;
    border-radius: 5px;
    margin-top: 8px;
    display: block;
    cursor: pointer;
    transform: scale(0.8);
  }

  .gallery-caption {
    pointer-events: none;
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    /* bottom: 8px; */
    /* left: 8px; */
    /* right: 8px; */
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: 3px;
    font-size: 24px;
    opacity: 0;
  }
</style>
