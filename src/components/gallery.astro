---
import { getGallery } from "../utils/sanity";
import { urlFor } from "../utils/image";
const gallery = await getGallery("featured");
export const prerender = false
---

<div
  id="gallery"
  class="w-screen min-h-[250vh] pb-32 light flex flex-col items-center gap-8 relative"
>
  <h1 class="text-6xl my-8 mt-32">Gallery</h1>
  <!-- <div class="grid grid-cols-2 md:grid-cols-3 gap-3 w-[80vw] max-w-6xl"> -->
  <div class="columns-2 md:columns-3 lg:columns-4 gap-4 w-[80vw] max-w-6xl">
    {
      gallery && gallery.gallery?.map((img) => {
        console.log(img);
        return (<img src={urlFor(img.asset).url()} />)
      })
    }
  </div>
</div>

<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  img {
    width: 100%;
    /* height: 100%; */
    /* aspect-ratio: 1/1; */
    /* object-fit: cover; */
    border-radius: 5px;
    margin-top: 8px;
  }
</style>
