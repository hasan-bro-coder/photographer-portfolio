---
import { getGallery } from "../utils/sanity";
import { urlFor } from "../utils/image";
const gallery = await getGallery("featured");
export const prerender = false
---

<section
  id="gallery"
  class="w-screen min-h-[250vh] h-full light flex flex-col items-center gap-8"
>
  <h1 class="text-6xl my-8 mt-32 gallery-title">Gallery</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 w-[80vw] max-w-6xl gallery-grid">
    {
      gallery.gallery?.map((img) => (
        <div class="gallery-item-wrapper group overflow-hidden rounded-lg">
          <img 
            src={urlFor(img.asset).url()}
            alt={img.caption || "Gallery image"}
            class="gallery-image w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="gallery-overlay"></div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    ScrollTrigger.getAll().forEach(trigger => trigger.kill());

    // Title fade in
    gsap.from(".gallery-title", {
      opacity: 0,
      y: 30,
      duration: 0.8,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".gallery-title",
        start: "top 80%",
        once: true,
      },
    });

    // Grid items pop animation
    ScrollTrigger.batch(".gallery-item-wrapper", {
      start: "top 80%",
      onEnter: (batch) =>
        gsap.to(batch, {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 0.7,
          stagger: 0.1,
          ease: "back.out(1.7)",
          overwrite: true,
        }),
      onLeaveBack: (batch) =>
        gsap.to(batch, {
          opacity: 0,
          scale: 0.7,
          y: 20,
          duration: 0.5,
          stagger: 0.05,
          overwrite: true,
        }),
    });

    // Set initial state
    gsap.set(".gallery-item-wrapper", { 
      opacity: 0, 
      scale: 0.7,
      y: 20
    });
  };

  window.addEventListener("DOMContentLoaded", initAnimations);
  document.addEventListener("astro:after-swap", initAnimations);
</script>

<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  
  .gallery-item-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    border-radius: 5px;
    overflow: hidden;
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
  }

  .gallery-overlay {
    display: none;
  }

  #gallery-con {
    grid-template-columns: repeat(3, 64px);
    grid-row: 64px;
  }
</style>
