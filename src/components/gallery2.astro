---
import { getGallery } from "../utils/sanity";
import { urlFor } from "../utils/image";
const gallery = await getGallery("featured");
export const prerender = false
---

<section
  id="gallery"
  class="w-screen min-h-[250vh] h-full light flex flex-col items-center gap-8"
>
  <h1 class="text-6xl my-8 mt-32">Gallery</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 w-[80vw] max-w-6xl">
    {
      gallery.gallery?.map((img) => (
        <img src={urlFor(img.asset).url()} />
      ))
    }
  </div>
</section>
<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border-radius: 5px;
  }
  #gallery-con {
    grid-template-columns: repeat(3, 64px);
    grid-row: 64px;
  }
</style>
