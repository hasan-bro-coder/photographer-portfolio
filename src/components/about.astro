</div>

<script>
  import {gsap} from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#about",
      start: "top 10%",
      end: "bottom top",
      scrub: 0.8,
    },
  });

  tl.from(".about-image", {
  //   opacity: 0,
    scale: 0.8,
    rotation: -10,
    y: 30,
    ease: "back.out(1.5)",
  }).from(
    ".about-text",
    {
      // opacity: 0,
      x: 40,
      ease: "power3.out",
    },
    "<0.1" // slight offset, starts almost with image
  );
</script>

<style>
  .about-content {
    opacity: 1; /* removed the opacity:0 — GSAP handles it via `from` */
  }
  #separator {
    background-color: white;
    width: 80%;
    height: 1px;
  }
#about-container {
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: auto;
  place-content: center;
  place-items: center;
}

@media (min-width: 640px) {
  #about-container {
    grid-template-columns: 1fr 1px 2fr;
    grid-template-rows: 1fr;
  }
  #separator {
    width: 1px;
    height: 100%;
  }
}
  nav {
    z-index: 100;
  }
  svg {
    fill: white;
    width: 32px;
    height: 32px;
  }
  .about-image {
    border-radius: 8px;
    object-fit: cover;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  /* REMOVED the conflicting CSS slideIn animation on .about-text */
</style>