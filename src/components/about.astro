<div id="about-con" class="con w-screen h-[150vh] relative flex justify-center items-center">
  <section
    id="about"
    class="dark w-screen h-[150vh] flex justify-center items-center"
  >
    <div
      id="about-container"
      class="w-[80%] sm:max-h-64 gap-8 about-content"
    >
      <img
        class="about-image max-w-[80%]"
        src="pfp.jpg"
        alt="Hasanur Rahman - Professional Photographer"
        loading="lazy"
      />
      <div id="separator" ></div>
      <div class="flex flex-col gap-2 about-text">
        <h2 class="text-3xl font-bold">About Me</h2>
        <p class="works text-xl">Professional Photographer</p>
        <p class="mt-4">
          Hi, I'm <span class="font-colitezserif">Hasan</span>, based in Dhaka,
          Bangladesh. With a passion for freezing moments in time, I specialize
          in capturing the essence and emotions of every frame. Whether it's
          portraits, events, or landscapes, I bring creativity and technical
          expertise to every project. My goal is to tell your story through
          beautiful, timeless photography.
        </p>
