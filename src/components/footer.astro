---
// You can import images or data here if needed
const currentYear = new Date().getFullYear();
---
<footer class="light py-12 px-8 w-screen relative ">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-12">
      
      <div class="flex flex-col gap-6">
        <div class="flex gap-4 text-xl">
          <a href="https://instagram.com" rel="noopener noreferrer" target="_blank" aria-label="Follow us on Instagram" class="hover:opacity-80 transition-opacity"><i class="ph-instagram-logo"></i></a>
          <a href="https://facebook.com" rel="noopener noreferrer" target="_blank" aria-label="Follow us on Facebook" class="hover:opacity-80 transition-opacity"><i class="ph-facebook-logo"></i></a>
          <a href="https://pinterest.com" rel="noopener noreferrer" target="_blank" aria-label="Follow us on Pinterest" class="hover:opacity-80 transition-opacity"><i class="ph-pinterest-logo"></i></a>
        </div>
        
        <nav class="flex flex-col gap-1 text-sm tracking-wide uppercase">
          <a href="/" class="hover:text-white transition-colors">home</a>
          <a href="/#about-con" class="hover:text-white transition-colors">about</a>
          <a href="/#contact-section" class="hover:text-white transition-colors">contact</a>
          <a href="/gallery" class="hover:text-white transition-colors">gallery</a>
          <a href="/sitemap.xml" class="hover:text-white transition-colors text-xs">sitemap</a>
        </nav>
      </div>
      <p class="text-3xl">PHOTOGRAPHER</p>
      <div class="flex flex-col items-center text-center justify-center">
        <img 
          src="/pfp.jpg" 
          alt="Hasanur Rahman - Professional Photographer" 
          class="h-32 w-auto mb-4"
          loading="lazy"
        />
      </div>

      
    </div>

    <div class="mt-16 text-center text-[10px] opacity-70 tracking-widest leading-loose font-mono">
      <p>&copy; {currentYear} Hasanur Rahman Professional Photography</p>
      <p>DESIGNED & DEVELOPED BY <a href="https://hsn.is-a.dev/" rel="noopener noreferrer" target="_blank">HASANUR RAHMAN</a></p>
      <div class="mt-4 flex justify-center">
         <span class="inline-block border-b border-[#d9c5b2] w-6 opacity-40"></span>
      </div>
    </div>
  </div>
</footer>