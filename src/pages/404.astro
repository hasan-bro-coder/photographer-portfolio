---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Page Not Found | Hasanur Rahman - Photographer"
  description="The page you are looking for could not be found. Browse our photography gallery and portfolio instead."
  keywords="404, page not found, error"
  canonicalURL= {import.meta.env.BASE_URL}
>
  <div class="dark min-h-screen w-full flex flex-col items-center justify-center px-6 py-20">
    <div class="max-w-2xl text-center space-y-8">
      <h1 class="text-6xl md:text-8xl font-bold text-white mb-4">404</h1>
      
      <h2 class="text-3xl md:text-4xl text-white font-colitezserif mb-4">
        Page Not Found
      </h2>
      
      <p class="text-[#d9c5b2]/70 text-lg mb-8">
        The page you're looking for doesn't exist or has been moved. Let's get you back to capturing memories.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-3 bg-white text-black font-semibold rounded hover:bg-[#d9c5b2] transition-colors">
          Return to Home
        </a>
        <a href="/gallery" class="px-8 py-3 border border-white text-white font-semibold rounded hover:bg-white/10 transition-colors">
          Browse Gallery
        </a>
      </div>
    </div>
  </div>
</Layout>