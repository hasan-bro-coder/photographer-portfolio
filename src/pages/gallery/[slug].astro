import { getGallery, getAllGallery } from "../../utils/sanity";
import Layout from "../../layouts/Layout.astro";
import Contact from "../../components/contact.astro";
import type { InferGetStaticParamsType } from "astro";
import { urlFor } from "../../utils/image";

// export async function getStaticPaths() {
//   const posts = await getAllGallery();
//   return posts.map((post) => ({
//     params: { slug: encodeURI(post.slug.current) },
//   }));
// }

const { slug } = Astro.params;

const images = await getGallery(slug || "featured");

export const prerender = false;

const pageTitle = images?.title || "Photography Gallery";
const pageDescription =
  images?.detail || "Explore this curated photography collection";
---

<Layout
  title={`${pageTitle} | Hasanur Rahman - Photographer`}
  description={pageDescription}
  keywords={`${pageTitle}, photography, gallery, Hasanur Rahman`}
  canonicalURL={import.meta.env.BASE_URL + `/gallery/${slug}`}
>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ImageGallery",
      "name": "${pageTitle}",
      "description": "${pageDescription}",
      "url": "https://photographer-portfolio-blush-theta.vercel.app/gallery/${slug}",
      "creator": {
        "@type": "Person",
        "name": "Hasanur Rahman"
      }
    }
  </script>
  <main class="dark min-h-screen pt-64 pb-16 px-6 md:px-12">
    <header id="gallery-header" class="text-center mb-16 md:mb-32">
      <h1 class="text-4xl md:text-5xl tracking-widest uppercase mb-4">
        {images?.title || "Memories Captured"}
      </h1>
      <p class="text-[#d9c5b2]/60 text-sm md:text-base max-w-lg mx-auto italic">
        {images?.detail || "A curation of moments from the world."}
      </p>
    </header>

    <div
      class="gallery-wrapper max-w-7xl mx-auto columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4"
    >
      {
        images &&
          images.gallery?.map((item) => (
            <div class="gallery-item break-inside-avoid opacity-0 translate-y-8 group relative overflow-hidden border border-[#d9c5b2]/10 shadow-lg cursor-pointer bg-[#5a483b]">
              <img
                src={urlFor(item.asset).url()}
                alt={
                  item.caption ||
                  `${images.title} - Photography by Hasanur Rahman`
                }
                loading="lazy"
                class="w-full h-auto object-cover transition-transform duration-700 ease-in-out group-hover:scale-110"
              />
              {item.caption && (
                <div class="gallery-caption pointer-events-none absolute inset-0 flex justify-center items-center bg-black/70 text-white text-lg opacity-0 transition-opacity duration-400">
                  <span class="px-4 text-center tracking-widest">
                    {item.caption}
                  </span>
                </div>
              )}
            </div>
          ))
      }
    </div>

    <div class="mt-20 flex justify-center opacity-30">
      <span class="inline-block border-b border-[#d9c5b2] w-12"></span>
    </div>
  </main>
  <Contact />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.getAll().forEach((t) => t.kill());
  const items = document.querySelectorAll(".gallery-item");

  if (items.length > 0) {
    ScrollTrigger.refresh();

    ScrollTrigger.batch(".gallery-item", {
      start: "top 95%",
      end: "bottom 5%", // Triggers when the bottom of the image reaches 5% from the top
      onEnter: (batch) =>
        gsap.to(batch, { opacity: 1, y: 0, stagger: 0.1, overwrite: true }),
      onLeave: (batch) =>
        gsap.to(batch, { opacity: 0, y: -20, overwrite: true }), // Fades out when scrolling up past it
      onEnterBack: (batch) =>
        gsap.to(batch, { opacity: 1, y: 0, stagger: 0.1, overwrite: true }),
      onLeaveBack: (batch) =>
        gsap.to(batch, { opacity: 0, y: 20, overwrite: true }), // Fades out when scrolling down past it
    });
  }

  document.querySelectorAll(".gallery-item").forEach((item) => {
    const caption = item.querySelector(".gallery-caption");
    if (!caption) return;
    item.addEventListener("mouseenter", () =>
      gsap.to(caption, { opacity: 1, duration: 0.1, ease: "power2.out" }),
    );
    item.addEventListener("mouseleave", () =>
      gsap.to(caption, { opacity: 0, duration: 0.1, ease: "power2.in" }),
    );
  });
</script>

<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }

  .gallery-item-wrapper {
    position: relative;
    border-radius: 5px;
    overflow: hidden;
  }

  .gallery-image {
    width: 100%;
    border-radius: 5px;
    margin-top: 8px;
    display: block;
    cursor: pointer;
    transform: scale(0.8);
  }

  .gallery-caption {
    pointer-events: none;
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    /* bottom: 8px; */
    /* left: 8px; */
    /* right: 8px; */
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: 3px;
    font-size: 24px;
    opacity: 0;
  }
</style>
